@baseUrl = http://localhost:8000/api
@userId = 4

GET {{baseUrl}}/users/{{userId}}/todos/?completed_before=2026-01-20&limit=5&page=2
Accept: application/json

###
POST {{baseUrl}}/users/{{userId}}/todos/
Content-Type: application/json
Accept: application/json

{
    "name":"洗濯",
    "difficulty":3,
    "reward":7,
    "memo":"3時までにやる"
}

####
@todoId = 90

####
GET {{baseUrl}}/todos/{{todoId}}/
Accept: application/json

###
PATCH {{baseUrl}}/todos/{{todoId}}/
Content-Type: application/json
Accept: application/json

{
    "is_completed": true
}

###
DELETE {{baseUrl}}/todos/{{todoId}}/
Accept: application/json


